import pg from 'pg';
const { Pool } = pg;

const pool = new Pool({
  connectionString: process.env.POSTGRES_URL,
  ssl: { rejectUnauthorized: false }
});

export default async function handler(request, response) {
  if (request.method !== 'POST') return response.status(405).send('Method Not Allowed');

  const { name, score, difficulty } = request.body;

  try {
    // 1. 난이도 매칭 (Difficulty 테이블에서 id 조회)
    const diffResult = await pool.query('SELECT id FROM Difficulty WHERE db_value = $1', [difficulty]);
    const diffId = diffResult.rows[0]?.id;

    if (!diffId) return response.status(400).json({ error: "난이도 정보가 올바르지 않습니다." });

    // 2. 이번 달 내에 같은 닉네임이 있는지 확인
    const checkUser = await pool.query(`
      SELECT id, score FROM quiz_ranking 
      WHERE name = $1 AND created_at >= DATE_TRUNC('month', CURRENT_DATE)
    `, [name]);

    if (checkUser.rows.length > 0) {
      // 3. 기록이 있다면: 이번 점수가 더 높을 때만 업데이트 (최고 기록 경신)
      if (score > checkUser.rows[0].score) {
        await pool.query(`
          UPDATE quiz_ranking 
          SET score = $1, difficulty_id = $2, created_at = NOW() 
          WHERE id = $3
        `, [score, diffId, checkUser.rows[0].id]);
        return response.status(200).json({ success: true, message: "신기록 경신 완료! ✨" });
      }
      return response.status(200).json({ success: true, message: "기존 점수가 더 높습니다." });
      
    } else {
      // 4. 기록이 없다면: 새로 삽입 (name, score, difficulty_id 순서)
      await pool.query(`
        INSERT INTO quiz_ranking (name, score, difficulty_id, created_at) 
        VALUES ($1, $2, $3, NOW())
      `, [name, score, diffId]);
      
      return response.status(200).json({ success: true, message: "랭킹 등록이 완료되었습니다! 🏆" });
    }
  } catch (error) {
    console.error(error);
    return response.status(500).json({ error: error.message });
  }
}